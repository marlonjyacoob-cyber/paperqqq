# Copy this file to .env and fill in your Alpaca PAPER trading credentials.
# Get keys at: https://app.alpaca.markets (switch to Paper Trading in the dashboard)
# NEVER use live trading keys here.

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
